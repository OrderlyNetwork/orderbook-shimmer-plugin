{
  "name": "@orderly.network/package-template",
  "version": "0.0.1",
  "description": "Template for creating a new Orderly.network package",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup && pnpm run build:css",
    "build:css": "tailwindcss build -i src/tailwind.css -o dist/styles.css --minify",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "@orderly.network/hooks": ">=2.10.1",
    "@orderly.network/i18n": ">=2.10.1",
    "@orderly.network/ui": ">=2.10.1",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@orderly.network/ts-config": "^0.0.2",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.3.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.4",
    "tailwindcss-animate": "^1.0.6",
    "tsup": "^8.5.1",
    "typescript": "^5.1.6"
  }
}